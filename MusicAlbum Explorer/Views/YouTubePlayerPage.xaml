<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MusicAlbum_Explorer.Views.YouTubePlayerPage"
             Title="Lecteur YouTube">
    <ContentPage.Content>
        <Grid>
            <WebView x:Name="PlayerWebView" />

            <!-- Loading indicator centered -->
            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                               VerticalOptions="Center" HorizontalOptions="Center" />

            <!-- Fallback panel shown when navigation fails -->
            <StackLayout x:Name="FallbackPanel" IsVisible="False" VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="24" BackgroundColor="#22000000">
                <Label Text="Erreur de configuration du lecteur vidéo" TextColor="White" HorizontalOptions="Center" />
                <Button x:Name="OpenExternalButton" Text="Regarder la vidéo sur YouTube" Clicked="OnOpenExternalClicked" />
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>
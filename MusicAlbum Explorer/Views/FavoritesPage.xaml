<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MusicAlbum_Explorer.Views.FavoritesPage"
             Title="Favoris">

    <VerticalStackLayout Padding="12" Spacing="8">
        <Label Text="Musiques favorites" FontSize="20" FontAttributes="Bold" />

        <CollectionView x:Name="FavoritesCollection" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnDefinitions="60,*,Auto" RowDefinitions="Auto">
                        <Image Grid.Column="0" Source="{Binding Cover}" Aspect="AspectFill" HeightRequest="50" WidthRequest="50" />

                        <StackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Artist}" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding Album}" FontSize="12" TextColor="Gray" />
                        </StackLayout>

                        <Button Grid.Column="2" Text="Supprimer" Clicked="OnRemoveClicked" CommandParameter="{Binding Id}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>

</ContentPage>